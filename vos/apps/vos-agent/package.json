{
  "name": "vos-agent",
  "version": "0.1.0",
  "description": "VOS Agent: the TypeScript coding-agent backend for VeriSpecOSLab.",
  "type": "module",
  "exports": {
    ".": "./app/main.ts",
    "./headless": "./app/headless.ts"
  },
  "bin": {
    "vos-agent": "./app/main.ts"
  },
  "scripts": {
    "start": "bun run app/main.ts",
    "dev": "bun run app/main.ts",
    "build": "bun build --compile ./app/main.ts --outfile dist/vos-agent",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "openai": "^6.16.0",
    "vos-platform": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mdast": "^4.0.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
