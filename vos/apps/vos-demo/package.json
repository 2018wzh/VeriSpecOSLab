{
  "name": "vos-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./app/main.ts"
  },
  "scripts": {
    "start": "bun run app/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:real-llm": "VOS_DEMO_REAL_LLM=1 bun test tests/real-llm.test.ts",
    "dev": "vite --config web/vite.config.ts --host 127.0.0.1 --port 5174",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "bun run build:web && bun build ./app/main.ts --outdir dist --target bun"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "vite": "^7.2.7",
    "vos-agent": "workspace:*",
    "vos-core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
