{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "vos-agent/headless": ["../vos-agent/app/headless.ts"]
    },
    "types": ["bun"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["app/**/*", "tests/**/*", "web/src/**/*", "web/vite.config.ts"]
}
