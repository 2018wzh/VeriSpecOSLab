{
  "name": "vos",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "vos": "./dist/vos.exe"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "prepare": "bun run build",
    "vos": "bun run vos/apps/vos-cli/app/main.ts",
    "typecheck": "cd vos && bun run typecheck",
    "test": "cd vos && bun run test"
  }
}