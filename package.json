{
  "name": "vos",
  "version": "0.1.0",
  "description": "Spec-first OS lab CLI",
  "type": "module",
  "bin": {
    "vos": "./bin/vos.js"
  },
  "files": [
    "bin/",
    "README.md"
  ],
  "dependencies": {
    "vos-bin": "0.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
