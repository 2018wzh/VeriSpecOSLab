{
  "name": "vos",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.0"
  },
  "bin": {
    "vos": "./bin/vos.js"
  },
  "files": [
    "bin/",
    "scripts/install-prebuilt.mjs",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "postinstall": "node ./scripts/install-prebuilt.mjs",
    "test:installer": "bun test scripts/tests/build.test.ts && node --test scripts/tests/install-prebuilt.test.mjs",
    "vos": "bun run vos/apps/vos-cli/app/main.ts",
    "typecheck": "cd vos && bun run typecheck",
    "test": "cd vos && bun run test"
  }
}
